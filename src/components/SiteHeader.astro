---
import { navigation, siteName } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="border-b border-white/10">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-6 py-6 sm:px-10 lg:flex-row lg:items-center lg:justify-between lg:px-16">
    <a class="text-lg font-semibold tracking-tight" href="/">{siteName}<span class="text-amber-200">.</span></a>
    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap gap-x-5 gap-y-3 text-sm text-stone-300">
        {navigation.map((item) => (
          <li>
            <a
              class:list={{ "text-amber-200": currentPath === item.href, "transition hover:text-white": true }}
              href={item.href}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
