---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="max-w-3xl">
  {eyebrow && <p class="mb-4 text-sm font-medium tracking-[0.18em] text-amber-200 uppercase">{eyebrow}</p>}
  <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-6xl">{title}</h1>
  <p class="mt-6 text-lg leading-8 text-stone-300 sm:text-xl">{description}</p>
</section>
