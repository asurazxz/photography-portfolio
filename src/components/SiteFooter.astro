---
import { socialLinks } from "../data/site";
---

<footer class="border-t border-white/10">
  <div class="mx-auto flex max-w-7xl flex-col gap-5 px-6 py-8 text-sm text-stone-400 sm:px-10 sm:flex-row sm:items-center sm:justify-between lg:px-16">
    <p>© {new Date().getFullYear()} Denzel Marani.</p>
    <ul class="flex flex-wrap gap-x-5 gap-y-2">
      {socialLinks.map((link) => (
        <li><a class="transition hover:text-white" href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
      ))}
    </ul>
  </div>
</footer>
